# Database — Fly managed Postgres connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/clusterpilot

# Clerk — from Clerk dashboard → Configure → API Keys
CLERK_SECRET_KEY=
# Clerk webhook secret — from Clerk dashboard → Webhooks → signing secret
CLERK_WEBHOOK_SECRET=
# Stripe — from Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=
# Stripe webhook secret — from Stripe dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=
# Price IDs — from Stripe dashboard → Products
STRIPE_PRICE_ID_PROD=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# Resend — from Resend dashboard → API Keys
RESEND_API_KEY=

# Anthropic master key (used by proxy endpoint — daemon never holds this)
ANTHROPIC_API_KEY=

# App
ENVIRONMENT=development
